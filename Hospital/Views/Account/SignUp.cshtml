@model Hospital.Models.ViewModels.SignUpModel
@{
    ViewData["Title"] = "Sign Up";
}

<!DOCTYPE html>
<h1>@ViewData["Title"]</h1>
<html lang="en">
<body>

<div class="sign-up-card">
    <div asp-validation-summary="All" class="text-danger"></div>
    <form asp-controller="Account" asp-action="SignUp" method="post">
        <div class="input">
            <label asp-for="@Model.name">Username</label>
            <input asp-for="@Model.name" placeholder="Enter username"/>
        </div>
        <div class="input">
            <label asp-for="password">Password</label>
            <input asp-for="password" placeholder="Enter password"/>
        </div>
        <div class="form-group">
            <label asp-for="Role" class="control-label"></label>
            <select asp-for="Role" 
                    class="form-control" 
                    asp-items="Html.GetEnumSelectList<Hospital.Models.Person.UserRole>()">
                <option value="">-- Select Role --</option>
            </select>
            <span asp-validation-for="Role" class="text-danger"></span>
        </div>
        <div class="input">
            <label asp-for="specialty">Specialty</label>
            <input asp-for="specialty" placeholder="Enter specialty"/>
        </div>
        <div class="input">
            <label asp-for="email">Email</label>
            <input asp-for="email" placeholder="Enter Email"/>
        </div>
        <button type="submit" class="button-Sign-In">Sign Up</button>
    </form>
</div>
</body>
</html>