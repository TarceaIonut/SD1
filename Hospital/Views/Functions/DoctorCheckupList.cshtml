@model Hospital.Models.ViewModels.DoctorCheckupsFunctions
@{
    ViewData["Title"] = "Doctor Checkup List";
}

<!DOCTYPE html>

<h1>@ViewData["Title"]</h1>
<div asp-validation-summary="All" class="text-danger"></div>
<table class="accounts table">
    <thead>
    <tr>
        <th>Id</th>
        <th>Doctor Name</th>
        <th>Doctor Email</th>
        <th>Speciality</th>
        <th>Patient Name</th>
        <th>Patient Email</th>
        <th>Appointment Date</th>
        <th>Description</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var c in Model.DoctorCheckups) {
        <tr>
            <th>@c.Id</th>
            <td>@c.Doctor.Account?.Username</td>
            <th>@c.Doctor.Email</th>
            <td>@c.Doctor.Specialty</td>
            <th>@c.Patient.Account?.Username</th>
            <th>@c.Patient.Email</th>
            <th>@c.AppointmentDate.ToString("f")</th>
            <th>@c.Description</th>
        </tr>
    }
    </tbody>
</table>
@if (@Model.DoctorCheckups.Count > 0) {
    if (@Context.Session.GetString("UserRole") != null &&
        @Context.Session.GetString("UserRole")!.Equals("Patient") == false) {
        <form method="post">
            <div class="input">
                <label asp-for="Id">Checkup Id</label>
                <input asp-for="Id" placeholder="Enter Checkup Id"/>
            </div>
            <div class="input">
                <label asp-for="Description">Description</label>
                <input asp-for="Description" placeholder="Enter Description" type="text"/>
            </div>
            <div class="input">
                <label asp-for="AppointmentDate">Appointment Date</label>
                <input asp-for="AppointmentDate" placeholder="Enter DAppointment Date"/>
            </div>
        
            <button type="submit" asp-controller="Functions" asp-action="DoctorCheckupDelete">Delete</button>
            <button type="submit" asp-controller="Functions" asp-action="DoctorCheckupUpdate">Update</button>
        </form>
    }
    <form method="post">
        <div class="form-group">
            <label asp-for="sortOn" class="control-label"></label>
            <select asp-for="sortOn" 
                    class="form-control" 
                    asp-items="Html.GetEnumSelectList<Hospital.Models.ViewModels.DoctorCheckupsFunctions.SortOn>()">
                <option value="">-- Select Role --</option>
            </select>
            <span asp-validation-for="sortOn" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="sortOrder" class="control-label"></label>
            <select asp-for="sortOrder" 
                    class="form-control" 
                    asp-items="Html.GetEnumSelectList<Hospital.Models.ViewModels.DoctorCheckupsFunctions.SortOrder>()">
                <option value="">-- Select Role --</option>
            </select>
            <span asp-validation-for="sortOrder" class="text-danger"></span>
        </div>
        <button type="submit" asp-controller="Functions" asp-action="DoctorCheckupSort">Sort</button>
    </form>
    
}
